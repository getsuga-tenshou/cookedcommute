# Copy to .env and fill in. Never commit the real .env (it is git-ignored).

# --- Snowflake (key-pair auth; generate with: python scripts/gen_snowflake_key.py) ---
SNOWFLAKE_ACCOUNT=youraccount-region        # e.g. ab12345-west-europe
SNOWFLAKE_USER=YOUR_SNOWFLAKE_USER
SNOWFLAKE_PRIVATE_KEY_PATH=/absolute/path/to/rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_ROLE=PARKPULSE_ROLE
SNOWFLAKE_WAREHOUSE=PARKPULSE_WH
SNOWFLAKE_DATABASE=PARKPULSE
SNOWFLAKE_SCHEMA=RAW
# SNOWFLAKE_PASSWORD=                        # unused — programmatic access requires key-pair

# --- Azure ADLS Gen2 raw landing (leave blank to land only to the local ./lake in dev) ---
ADLS_ACCOUNT=
ADLS_FILESYSTEM=raw
ADLS_CONNECTION_STRING=

# --- Data sources (all free / open) ---
NDW_TRAFFICSPEED_URL=https://opendata.ndw.nu/trafficspeed.xml.gz
NDW_MEASUREMENT_URL=https://opendata.ndw.nu/measurement.xml.gz
AMS_PARKING_URL=https://npropendata.rdw.nl/parkingdata/v2

# --- TomTom Freemium key (live flow tiles + incidents) ---
TOMTOM_API_KEY=

# --- Ingestion behaviour ---
POLL_TRAFFIC_SECONDS=60
POLL_PARKING_SECONDS=300
LAKE_DIR=./lake
USE_SYNTHETIC=false

# --- Amsterdam bounding box (clips the national NDW feed to the city) ---
AMS_BBOX_MIN_LAT=52.30
AMS_BBOX_MAX_LAT=52.42
AMS_BBOX_MIN_LON=4.78
AMS_BBOX_MAX_LON=5.02
